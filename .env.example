# =============================================================================
# Webnua — environment variables.
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored; this `.env.example` is the committed template. Never commit real
# keys.
# =============================================================================

# --- Supabase: client-safe (exposed to the browser) --------------------------
# The project URL and the publishable (anon) key. Both are safe to ship to the
# client — row access is enforced by RLS, not by hiding these. The exact key
# name/type (legacy `anon` JWT vs the newer publishable key) is confirmed
# against the project in Phase 1 session A.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: server-only (NEVER prefix with NEXT_PUBLIC_) ------------------
# The service-role / secret key bypasses RLS. Used only in server contexts
# (route handlers, server actions, migration scripts). Exposing it to the
# client would defeat every RLS policy — keep it out of any NEXT_PUBLIC_ var.
SUPABASE_SERVICE_ROLE_KEY=

# --- Integrations: Phase 4 (not used yet) ------------------------------------
# Twilio / Meta / Google Business Profile / Stripe / Resend credentials land
# here when Phase 4 wires the integration edge functions. Left blank for now.
